/* 
  Nexa v2.0 — @tool 注解示例
  演示 Harness T-dimension: 零成本工具绑定
*/

@tool("Search the web for information")
fn web_search(query: string): string {
    print "Searching for query";
    return "Search results";
}

agent SearchAgent {
    prompt: "You are a search agent that finds information online."
}

flow main {
    print "=== v2.0 @tool Demo ===";
    result = SearchAgent.run("Find latest AI news");
    print result;
}
/* 
  Nexa v2.0 — fork/merge 多分支探索示例
  演示 Harness S-dimension: Tree-of-Thoughts
  Grammar: fork [expr1, expr2] merge best_of;
*/

agent ExploreAgent {
    prompt: "You are an exploration agent that tries different approaches."
}

flow main {
    print "=== v2.0 fork/merge Demo ===";
    
    fork [ExploreAgent.run("Try approach A"), ExploreAgent.run("Try approach B")] merge best_of;
    
    print "Fork merged with best_of strategy.";
}
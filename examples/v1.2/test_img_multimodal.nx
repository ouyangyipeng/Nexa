// 测试 img 多模态功能
// 测试点：1-12 覆盖各种 img 场景

// ==================== 测试点 1: 基本 img 调用 ====================
agent Img1_Analyzer {
    prompt: "分析图像内容"
}

// ==================== 测试点 2: JPEG 格式支持 ====================
agent Img2_JPEGHandler {
    prompt: "处理 JPEG 图像"
}

// ==================== 测试点 3: PNG 格式支持 ====================
agent Img3_PNGHandler {
    prompt: "处理 PNG 图像"
}

// ==================== 测试点 4: GIF 格式支持 ====================
agent Img4_GIFHandler {
    prompt: "处理 GIF 图像"
}

// ==================== 测试点 5: WebP 格式支持 ====================
agent Img5_WebPHandler {
    prompt: "处理 WebP 图像"
}

// ==================== 测试点 6: 图片传递给 Agent ====================
agent Img6_VisionAgent {
    prompt: "视觉分析 Agent"
}

// ==================== 测试点 7: 图片与文本混合输入 ====================
agent Img7_MultiModalAgent {
    prompt: "处理图像和文本的混合输入"
}

// ==================== 测试点 8: 图片不存在错误处理 ====================
agent Img8_FallbackAgent {
    prompt: "备用处理 Agent"
}

// ==================== 测试点 9: 无效图片格式处理 ====================
agent Img9_Validator {
    prompt: "验证图像格式"
}

// ==================== 测试点 10: 图片在管道中传递 ====================
agent Img10_Step1 {
    prompt: "图像处理步骤 1"
}

agent Img10_Step2 {
    prompt: "图像处理步骤 2"
}

// ==================== 测试点 11: 图片在 DAG 中传递 ====================
agent Img11_Parallel1 {
    prompt: "并行图像处理 1"
}

agent Img11_Parallel2 {
    prompt: "并行图像处理 2"
}

agent Img11_Merger {
    prompt: "合并图像处理结果"
}

// ==================== 测试点 12: Base64 编码验证 ====================
agent Img12_Encoder {
    prompt: "验证图像编码"
}

// ==================== Flow 测试 ====================
flow main {
    print("========== img 多模态测试开始 ==========")
    
    // 测试点 1: 基本 img 调用
    print("Test 1: 基本 img 调用")
    // img_data = img("docs/img/logo.jpg")
    // result1 = Img1_Analyzer.run("分析图像", img_data)

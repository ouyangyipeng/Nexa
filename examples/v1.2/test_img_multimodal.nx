// ==================== 实际图像测试 Flow ====================
flow test_real_image {
    print("测试实际图像处理...")
    
    // 加载项目中的 logo
    logo = img("docs/img/logo.jpg")
    
    // 分析图像
    description = Img6_VisionAgent.run("请描述这张图片的内容", logo)
    print("图像描述: " + description)
}